generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subestacao {
  id                   Int       @id @default(autoincrement())
  nome                 String    @db.VarChar(100)
  codigo_operacional   String    @unique @db.VarChar(20)
  tipo                 String    @db.VarChar(20) // Transporte ou Distribuição
  tensao_kv_entrada    Float?
  tensao_kv_saida      Float?
  capacidade_total_mva Float?
  municipio            String?   @db.VarChar(50)
  latitude             Float?
  longitude            Float?
  gps                  String?
  status               String    @default("Ativa") @db.VarChar(20)
  data_instalacao      DateTime? @db.Date

  criado_em     DateTime             @default(now())
  atualizado_em DateTime             @updatedAt
  pts           PostoTransformacao[]

  @@map("subestacao")
}

model Utilizador {
  id               Int                  @id @default(autoincrement())
  nome             String               @db.VarChar(200)
  email            String               @unique @db.VarChar(255)
  password_hash    String               @db.VarChar(255)
  role             String               @default("auditor") @db.VarChar(50)
  permissoes       Json                 @default("[]")
  telefone         String?              @db.VarChar(30)
  localizacao      String?              @db.Text
  gps              String?
  municipio        String?              @db.VarChar(150)
  provincia        String?              @db.VarChar(150)
  ativo            Boolean              @default(true)
  ultimo_acesso    DateTime?
  criado_em        DateTime             @default(now())
  atualizado_em    DateTime             @updatedAt
  pts_responsaveis PostoTransformacao[] @relation("Responsavel")
  inspecoes        Inspecao[]
  tarefas          Tarefa[]

  @@map("utilizador")
}

model Proprietario {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  nif           String?  @unique @db.VarChar(50)
  email         String?  @db.VarChar(255)
  telefone      String?  @db.VarChar(50)
  tipo_cliente  String?  @db.VarChar(100)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  // Dados Comerciais (Movidos de Cliente)
  concessionaria       String?  @db.VarChar(200)
  zona                 String?  @db.VarChar(100)
  operador             String?  @db.VarChar(200)
  conta_contrato       String?  @db.VarChar(50)
  parceiro_negocios    String?  @db.VarChar(100)
  categoria_tarifa     String?  @db.VarChar(50)
  txt_categoria_tarifa String?  @db.VarChar(100)
  montante_divida      Decimal? @db.Decimal(18, 2)
  num_facturas_atraso  Int?     @default(0)

  // Contactos de Auditoria
  responsavel_financeiro   String? @db.VarChar(200)
  contacto_resp_financeiro String? @db.VarChar(200)

  pts PostoTransformacao[]

  @@map("proprietario")
}

model PostoTransformacao {
  id              Int           @id @default(autoincrement())
  id_pt           String        @unique @db.VarChar(50)
  id_subestacao   Int
  subestacao      Subestacao    @relation(fields: [id_subestacao], references: [id], onDelete: Cascade)
  id_responsavel  Int?
  responsavel     Utilizador?   @relation("Responsavel", fields: [id_responsavel], references: [id])
  id_proprietario Int?
  proprietario    Proprietario? @relation(fields: [id_proprietario], references: [id])

  // ── Secção 0 — Tipo de PT ──────────────────────────────────────────
  localizacao         String  @db.Text
  gps                 String?
  latitude            Float?
  longitude           Float?
  altitude            Float?
  morada              String? @db.Text
  municipio           String? @db.VarChar(150)
  provincia           String? @db.VarChar(150)
  tipo_instalacao     String  @db.VarChar(100)
  nivel_tensao        String  @db.VarChar(50)
  potencia_kva        Float
  ano_instalacao      Int     @db.SmallInt
  fabricante          String? @db.VarChar(150)
  num_transformadores Int     @default(1) @db.SmallInt
  regime_exploracao   String? @db.VarChar(100)
  estado_operacional  String  @default("Operacional") @db.VarChar(50)

  // ── Secção 1 — Identificação Geral (PDF) ─────────────────────────
  designacao           String?   @db.VarChar(200)
  id_concessionaria    String?   @db.VarChar(50) // Código de identificação único
  concessao_operador   String?   @db.VarChar(200)
  concelho             String?   @db.VarChar(150)
  freguesia            String?   @db.VarChar(150)
  data_levantamento    DateTime? @db.Date
  tecnico_levantamento String?   @db.VarChar(200)
  num_habilitacao      String?   @db.VarChar(50)

  // ── Secção 3 — Suporte/Poste (PTC/AS/AI) ─────────────────────────
  tipo_poste        String? @db.VarChar(50)
  ref_poste         String? @db.VarChar(50)
  altura_poste      Float?
  esforco_poste     Float?
  esforco_poste_dan Float? // Esforço nominal em daN
  material_poste    String? @db.VarChar(50) // Betão, Metálico, Madeira
  ano_poste         Int?    @db.SmallInt
  estado_poste      String? @db.VarChar(50)
  equipamento_poste Json?

  // ── Secção 4 — Cabine/Invólucro (Cabinados) ──────────────────────
  tipo_cabine     String? @db.VarChar(50)
  dim_comprimento Float?
  dim_largura     Float?

  // ── Secção Validação e Assinaturas ──────────────────────────────
  supervisor_obra           String?   @db.VarChar(200)
  tecnico_assinatura_url    String?   @db.Text
  supervisor_assinatura_url String?   @db.Text
  data_validacao            DateTime? @db.Date
  validacao_status          String    @default("Pendente") @db.VarChar(20)

  // Observações / Anomalias (Secção 8)
  observacoes_gerais String? @db.Text

  // Dados de instalação legado compatíveis
  instalacao          String? @db.VarChar(100)
  equipamento         String? @db.VarChar(100)
  distrito_comuna     String? @db.VarChar(150)
  bairro              String? @db.VarChar(150)
  contrato            String? @db.VarChar(100)
  num_serie           String? @db.VarChar(100)
  divisao             String? @db.VarChar(100)
  denominacao_divisao String? @db.VarChar(200)
  unidade_leitura     String? @db.VarChar(100)
  num_localidade      String? @db.VarChar(100)
  bairro_num          String? @db.VarChar(50)
  rua                 String? @db.VarChar(200)

  // Dados de Auditoria de Ativo
  responsavel_tecnico_cliente String?   @db.VarChar(200)
  contacto_resp_tecnico       String?   @db.VarChar(200)
  canal_faturacao             String?   @db.VarChar(50)
  fornece_terceiros           Boolean   @default(false)
  empresa_manutencao          String?   @db.VarChar(200)
  data_ultima_manutencao      DateTime? @db.Date

  criado_em       DateTime        @default(now())
  atualizado_em   DateTime        @updatedAt
  inspecoes       Inspecao[]
  conformidade    Conformidade?
  transformadores Transformador[]
  media_tensao    MediaTensao?
  baixa_tensao    BaixaTensao?
  seguranca       Seguranca?
  infraestrutura  Infraestrutura?
  monitorizacao   Monitorizacao?
  manutencao      Manutencao?
  riscos          Risco[]
  tarefas         Tarefa[]

  @@map("posto_transformacao")
}

model Inspecao {
  id                  Int                @id @default(autoincrement())
  id_pt               String             @db.VarChar(50)
  pt                  PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_auditor          Int
  auditor             Utilizador         @relation(fields: [id_auditor], references: [id])
  id_tarefa           Int?
  tarefa              Tarefa?            @relation(fields: [id_tarefa], references: [id])
  data_inspecao       DateTime           @default(now()) @db.Date
  tipo                String             @default("Auditoria PTA") @db.VarChar(50)
  resultado           String?            @db.VarChar(50)
  nivel_urgencia      String?            @db.VarChar(20)
  observacoes         String?            @db.Text
  fotos               Json?
  terra_protecao      Float?
  terra_servico       Float?
  medicao_tensao      Json?
  dados_cliente_campo Json?
  proxima_inspecao    DateTime?          @db.Date
  criado_em           DateTime           @default(now())
  atualizado_em       DateTime           @updatedAt

  conformidade    Conformidade[]
  transformadores Transformador[]
  media_tensao    MediaTensao[]
  baixa_tensao    BaixaTensao[]
  seguranca       Seguranca[]
  infraestrutura  Infraestrutura[]
  monitorizacao   Monitorizacao[]
  manutencao      Manutencao[]
  riscos          Risco[]
  incongruencias  Incongruencia[]

  @@map("inspecao")
}

model Conformidade {
  id                   Int                @id @default(autoincrement())
  id_pt                String             @unique @db.VarChar(50)
  pt                   PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao          Int?
  inspecao             Inspecao?          @relation(fields: [id_inspecao], references: [id])
  licenciamento        Boolean            @default(false)
  projeto_aprovado     Boolean            @default(false)
  diagramas_unifilares Boolean            @default(false)
  plano_manutencao     Boolean            @default(false)
  registos_inspecao    Boolean            @default(false)
  normas_iec           Boolean            @default(false)
  normas_ieee          Boolean            @default(false)
  normas_locais        Boolean            @default(false)
  observacoes          String?            @db.Text
  criado_em            DateTime           @default(now())
  atualizado_em        DateTime           @updatedAt

  @@map("conformidade")
}

model Transformador {
  id                     Int                @id @default(autoincrement())
  id_pt                  String             @db.VarChar(50)
  pt                     PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao            Int?
  inspecao               Inspecao?          @relation(fields: [id_inspecao], references: [id])
  num_transformador      Int                @default(1) @db.SmallInt
  potencia_kva           Float
  tensao_primaria        Float
  tensao_secundaria      Float
  tipo_isolamento        String             @db.VarChar(100)
  classe_termica         String?            @db.VarChar(20)
  estado_oleo            String?            @db.VarChar(50)
  fugas                  Boolean            @default(false)
  estado_buchas          String?            @db.VarChar(100)
  temperatura_operacao   Float?
  resistencia_isolamento Float?
  ttr                    Float?
  dga                    String?            @db.Text
  // Campos do Formulário PDF (Secção 2)
  fabricante             String?            @db.VarChar(150)
  numero_serie           String?            @db.VarChar(100)
  ano_fabrico            Int?               @db.SmallInt
  nivel_isolamento       Float?
  ucc                    Float?
  frequencia             Float?             @default(50)
  grupo_ligacao          String?            @db.VarChar(20)
  tipo_arrefecimento     String?            @db.VarChar(50)
  observacoes            String?            @db.Text
  criado_em              DateTime           @default(now())
  atualizado_em          DateTime           @updatedAt

  @@unique([id_inspecao, num_transformador])
  @@map("transformador")
}

model MediaTensao {
  id                    Int                @id @default(autoincrement())
  id_pt                 String             @unique @db.VarChar(50)
  pt                    PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao           Int?
  inspecao              Inspecao?          @relation(fields: [id_inspecao], references: [id])
  tipo_celas            String?            @db.VarChar(150)
  estado_disjuntores    String?            @db.VarChar(100)
  estado_seccionadores  String?            @db.VarChar(100)
  reles_protecao        String?            @db.VarChar(150)
  coordenacao_protecoes Boolean            @default(false)
  aterramento_mt        Boolean            @default(false)
  // Tabela de Celas (Secção 5 PDF) — JSON array [{num, funcao, tipo_fabricante, corrente_nominal, estado, obs}]
  celas                 Json?
  observacoes           String?            @db.Text
  criado_em             DateTime           @default(now())
  atualizado_em         DateTime           @updatedAt

  @@map("media_tensao")
}

model BaixaTensao {
  id                     Int                @id @default(autoincrement())
  id_pt                  String             @unique @db.VarChar(50)
  pt                     PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao            Int?
  inspecao               Inspecao?          @relation(fields: [id_inspecao], references: [id])
  estado_qgbt            String?            @db.VarChar(100)
  barramentos            String?            @db.VarChar(100)
  disjuntores            String?            @db.VarChar(100)
  balanceamento_cargas   Boolean            @default(false)
  corrente_fase_a        Float?
  corrente_fase_b        Float?
  corrente_fase_c        Float?
  tensao                 Float?
  fator_potencia         Float?
  // Campos QGBT do Formulário PDF (Secção 6)
  fabricante_qgbt        String?            @db.VarChar(150)
  corrente_nominal_geral Float?
  corrente_nominal_saida Float?
  num_saidas_bt          Int?               @db.SmallInt
  transformador_corrente String?            @db.VarChar(100)
  tipo_ligacao_neutro    String?            @db.VarChar(50)
  disjuntor_geral        Boolean            @default(false)
  fusiveis_gerais        Boolean            @default(false)
  contagem_bt            Boolean            @default(false)
  telecontagem           Boolean            @default(false)
  observacoes            String?            @db.Text
  criado_em              DateTime           @default(now())
  atualizado_em          DateTime           @updatedAt

  @@map("baixa_tensao")
}

model Seguranca {
  id                     Int                @id @default(autoincrement())
  id_pt                  String             @unique @db.VarChar(50)
  pt                     PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao            Int?
  inspecao               Inspecao?          @relation(fields: [id_inspecao], references: [id])
  resistencia_terra      Float?
  protecao_raios         Boolean            @default(false)
  spd                    Boolean            @default(false)
  sinalizacao            Boolean            @default(false)
  combate_incendio       Boolean            @default(false)
  distancias_seguranca   Boolean            @default(false)
  // Campos Proteção e Terra (Secção 7 PDF)
  data_ultima_medicao    DateTime?          @db.Date
  rele_protecao_marca    String?            @db.VarChar(150)
  tipo_protecao_mt       String?            @db.VarChar(100)
  fusiveis_mt_calibre    String?            @db.VarChar(50)
  protecao_sobrecorrente Boolean            @default(false)
  protecao_neutro        Boolean            @default(false)
  protecao_max_corrente  Boolean            @default(false)
  protecao_diferencial   Boolean            @default(false)
  observacoes            String?            @db.Text
  criado_em              DateTime           @default(now())
  atualizado_em          DateTime           @updatedAt

  @@map("seguranca")
}

model Infraestrutura {
  id              Int                @id @default(autoincrement())
  id_pt           String             @unique @db.VarChar(50)
  pt              PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao     Int?
  inspecao        Inspecao?          @relation(fields: [id_inspecao], references: [id])
  estado_cabine   String?            @db.VarChar(100)
  ventilacao      Boolean            @default(false)
  drenagem        Boolean            @default(false)
  iluminacao      Boolean            @default(false)
  controlo_acesso Boolean            @default(false)
  observacoes     String?            @db.Text
  criado_em       DateTime           @default(now())
  atualizado_em   DateTime           @updatedAt

  @@map("infraestrutura")
}

model Tarefa {
  id            Int                 @id @default(autoincrement())
  titulo        String              @db.VarChar(200)
  descricao     String?             @db.Text
  id_auditor    Int
  auditor       Utilizador          @relation(fields: [id_auditor], references: [id])
  id_pt         String?             @db.VarChar(50)
  pt            PostoTransformacao? @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  data_prevista DateTime            @db.Date
  data_inicio   DateTime?
  data_fim      DateTime?
  status        String              @default("Pendente") @db.VarChar(50)
  tipo_tarefa   String              @default("Auditoria") @db.VarChar(50)
  prioridade    String              @default("Normal") @db.VarChar(20)
  checklist     Json?
  criado_em     DateTime            @default(now())
  atualizado_em DateTime            @updatedAt
  inspecoes     Inspecao[]

  @@map("tarefa")
}

model Monitorizacao {
  id                   Int                @id @default(autoincrement())
  id_pt                String             @unique @db.VarChar(50)
  pt                   PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao          Int?
  inspecao             Inspecao?          @relation(fields: [id_inspecao], references: [id])
  scada                Boolean            @default(false)
  sensores_temperatura Boolean            @default(false)
  sensores_corrente    Boolean            @default(false)
  sensores_vibracao    Boolean            @default(false)
  registo_eventos      Boolean            @default(false)
  comunicacao          String?            @db.VarChar(150)
  observacoes          String?            @db.Text
  criado_em            DateTime           @default(now())
  atualizado_em        DateTime           @updatedAt

  @@map("monitorizacao")
}

model Manutencao {
  id               Int                @id @default(autoincrement())
  id_pt            String             @unique @db.VarChar(50)
  pt               PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao      Int?
  inspecao         Inspecao?          @relation(fields: [id_inspecao], references: [id])
  historico_falhas String?            @db.Text
  mtbf             Float?
  mttr             Float?
  plano_preventivo Boolean            @default(false)
  plano_preditivo  Boolean            @default(false)
  sobressalentes   Boolean            @default(false)
  observacoes      String?            @db.Text
  criado_em        DateTime           @default(now())
  atualizado_em    DateTime           @updatedAt

  @@map("manutencao")
}

model Incongruencia {
  id                  Int      @id @default(autoincrement())
  id_inspecao         Int
  inspecao            Inspecao @relation(fields: [id_inspecao], references: [id], onDelete: Cascade)
  tipo                String   @db.VarChar(50)
  descricao           String?  @db.Text
  valor_cadastro      String?  @db.VarChar(200)
  valor_apurado       String?  @db.VarChar(200)
  confirmado          Boolean  @default(false)
  confirmado_por      Int?
  resolvido           Boolean  @default(false)
  notificou_comercial Boolean  @default(false)
  nivel_urgencia      String?  @db.VarChar(20)
  criado_em           DateTime @default(now())
  atualizado_em       DateTime @updatedAt

  @@map("incongruencia")
}

model Risco {
  id                    Int                @id @default(autoincrement())
  id_pt                 String             @db.VarChar(50)
  pt                    PostoTransformacao @relation(fields: [id_pt], references: [id_pt], onDelete: Cascade)
  id_inspecao           Int?
  inspecao              Inspecao?          @relation(fields: [id_inspecao], references: [id])
  sobrecarga            Boolean            @default(false)
  desequilibrio_fases   Boolean            @default(false)
  falhas_isolamento     Boolean            @default(false)
  redundancia           Boolean            @default(false)
  acesso_nao_controlado Boolean            @default(false)
  acesso_remoto         Boolean            @default(false)
  segmentacao_ot_it     Boolean            @default(false)
  logs_siem             Boolean            @default(false)
  nivel_risco_geral     String?            @db.VarChar(20)
  observacoes           String?            @db.Text
  criado_em             DateTime           @default(now())
  atualizado_em         DateTime           @updatedAt

  @@map("risco")
}
